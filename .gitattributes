# Normalize text files to LF in the repo, regardless of host OS.
# Working-tree checkouts can render as CRLF on Windows; the repo stays LF.
* text=auto eol=lf

# Source-like text — be explicit so encoding/eol stays consistent
*.py        text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.json      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.toml      text eol=lf
*.md        text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.svg       text eol=lf
*.sh        text eol=lf
*.ini       text eol=lf
*.cfg       text eol=lf
.env*       text eol=lf
.gitignore  text eol=lf
.gitattributes text eol=lf
LICENSE     text eol=lf

# Binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.zip   binary
*.gz    binary
*.tar   binary
*.pdf   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.otf   binary
